{
  "manifest_version": 3,
  "name": "AMZ Tools Extension 2",
  "version": "1.1",
  "description": "AMZ Tools Extension 2 - security partner for AMZ Tools access.",
  "action": {
    "default_title": "AMZ Tools Extension 2",
    "default_icon": {
      "16": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "browsingData",
    "cookies",
    "management",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "key": "",
  "content_scripts": [
    {
      "matches": [
        "https://amztools.org/*",
        "https://www.amztools.org/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ]
}